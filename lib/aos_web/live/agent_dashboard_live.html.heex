<div class="flex h-screen bg-gray-900 text-gray-100 font-mono text-[17px]">
  
  <!-- Left Pane: File Tree -->
  <div class="w-1/4 border-r border-gray-700 bg-gray-800 p-0 overflow-y-auto flex flex-col">
    <div class="h-12 border-b border-gray-700 flex items-center px-4 bg-gray-800 shrink-0">
      <h2 class="text-[15px] font-bold text-gray-400 uppercase tracking-wider">Workspace</h2>
    </div>
    <div class="p-4">
      <pre class="text-[15px] leading-relaxed text-gray-300"><%= @file_tree %></pre>
    </div>
  </div>

  <!-- Center Pane: Chat & Status -->
  <div class="w-1/2 flex flex-col bg-gray-900">
    
    <!-- Top Status Bar -->
    <div class="h-12 border-b border-gray-700 flex items-center justify-between px-4 bg-gray-800 shrink-0">
      <div class="flex items-center space-x-3">
        <span class={"w-3 h-3 rounded-full #{if @current_status == "Idle", do: "bg-green-500", else: "bg-yellow-500 animate-pulse"}"}></span>
        <span class="text-[15px] text-gray-400 font-medium">System:</span>
        <span class="font-bold text-[15px] text-blue-400">자율 진화형 에이전트 🧬</span>
      </div>

      <div class="flex items-center space-x-4">
        <span class="text-[13px] text-gray-500 italic"><%= @current_status %></span>
        <a href="/admin/skills" class="text-xs text-blue-400 hover:text-blue-300 font-bold uppercase tracking-wider border border-blue-900 px-2 py-1 rounded bg-blue-900/10 transition-all">
          Skills Admin
        </a>
      </div>
    </div>

  <!-- Chat History -->
    <div class="flex-1 overflow-y-auto p-6 space-y-6" id="chat-container" phx-hook="ScrollToBottom">
      <%= for {msg, idx} <- Enum.with_index(@messages) do %>
        <div id={"msg-#{idx}"} class={"flex flex-col #{if msg.role == "user", do: "items-end", else: "items-start"}"}>
          
          <div class={"max-w-[90%] rounded-xl p-4 #{if msg.role == "user", do: "bg-blue-900 text-blue-50", else: "bg-gray-800 text-gray-100 border border-gray-700"}"}>
            <div class="text-xs font-bold mb-2 opacity-60 uppercase tracking-widest">
              <%= msg.role %>
            </div>
            
            <div class="whitespace-pre-wrap font-sans leading-relaxed"><%= msg.content %></div>
            
            <!-- Inline Approval Buttons -->
            <%= if Map.get(msg, :type) == :approval do %>
              <div class="mt-4 p-4 bg-gray-950 rounded-lg border border-gray-700 shadow-inner">
                <div class="text-sm mb-3">Status: 
                  <span class={"font-bold #{cond do 
                    msg.status == "Approved" -> "text-green-400"
                    msg.status == "Rejected" -> "text-red-400"
                    true -> "text-yellow-400"
                  end}"}><%= msg.status %></span>
                </div>
                
                <%= if msg.status == "Pending" do %>
                  <div class="flex space-x-3">
                    <button phx-click="approve_tool" phx-value-ref={msg.approval_ref} class="px-4 py-2 bg-green-600 hover:bg-green-500 text-white rounded font-bold text-sm transition-all shadow-lg active:scale-95">
                      Approve (y)
                    </button>
                    <button phx-click="reject_tool" phx-value-ref={msg.approval_ref} class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white rounded font-bold text-sm transition-all shadow-lg active:scale-95">
                      Reject (n)
                    </button>
                  </div>
                <% end %>
              </div>
            <% end %>
            
          </div>
        </div>
      <% end %>
    </div>

    <!-- Input Area -->
    <div class="p-4 border-t border-gray-700 bg-gray-800 shrink-0">
      <form phx-submit="submit_message" id="chat-form" class="flex items-end space-x-4">
        <textarea 
          name="message" 
          id="chat-input"
          rows="3"
          placeholder="Ask Autonomous Evolutionary Agent to do something..." 
          class="flex-1 bg-gray-900 border border-gray-600 rounded-lg px-4 py-3 text-[17px] focus:outline-none focus:border-blue-500 text-white placeholder-gray-500 resize-none transition-colors min-h-[100px]"
          phx-hook="ChatInput"
        ><%= @input_value %></textarea>
        <button type="submit" class="px-6 py-4 bg-blue-600 hover:bg-blue-500 rounded-lg text-white font-bold transition-all shadow-lg active:scale-95 text-[17px] h-full self-stretch flex items-center justify-center min-w-[100px]">
          Send
        </button>
      </form>
    </div>
    
  </div>

  <!-- Right Pane: Code/Diff View -->
  <div class="w-1/4 border-l border-gray-700 bg-gray-800 p-0 overflow-y-auto flex flex-col">
    <div class="h-12 border-b border-gray-700 flex items-center px-4 bg-gray-800 shrink-0">
      <h2 class="text-[15px] font-bold text-gray-400 uppercase tracking-wider">Inspection Pane</h2>
    </div>
    
    <div class="p-4 flex-1">
      <%= if @active_diff == "" do %>
        <div class="h-full flex items-center justify-center text-gray-600 italic text-center px-4">
          Select a file or wait for agent modifications to view details here.
        </div>
      <% else %>
        <pre class="text-sm text-gray-300 whitespace-pre-wrap leading-snug"><%= @active_diff %></pre>
      <% end %>
    </div>
  </div>

</div>
