# Phoenix
SECRET_KEY_BASE={GENERATE_WITH_mix_phx.gen.secret}
PHX_HOST=localhost
PHX_SERVER=false

# Database
DATABASE_URL=ecto://postgres:postgres@localhost/aos_dev
POOL_SIZE=10

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD={CHANGE_ME}
# Prefer ADMIN_PASSWORD_HASH in shared/staging/prod environments.
# ADMIN_PASSWORD_HASH={ARGON2_OR_BCRYPT_HASH}

# API authentication
AOS_API_KEY={CHANGE_ME}

# LLM runtime
AGENT_RUNTIME_TYPE=api
AGENT_BASE_URL=http://localhost:8317/v1beta
AGENT_MODEL=models/gemini-3-pro-preview
AGENT_API_KEY={CHANGE_ME}
# AGENT_RUNTIME_TYPE=local
# AGENT_LOCAL_MODEL=google/gemma-2-2b-it

# Webhook integrations
WEBHOOK_SHARED_SECRET={CHANGE_ME}
SLACK_SHARED_SECRET={CHANGE_ME}
SLACK_SIGNING_SECRET={CHANGE_ME}

# Retention and API throttling
FAILED_RETENTION_DAYS=1
SUCCESS_RETENTION_DAYS=30
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW_MS=60000

# Evolution strategy layer
EVOLUTION_ENABLED=true
EVOLUTION_MUTATION_THRESHOLD=0.7
EVOLUTION_ARCHIVE_MIN_USAGE=5
EVOLUTION_ARCHIVE_SUCCESS_RATE=0.2
EVOLUTION_EXPERIMENT_MIN_USAGE=3
EVOLUTION_EXPLORATION_RATE=0.1
EVOLUTION_QUALITY_EVALUATOR_ENABLED=false
